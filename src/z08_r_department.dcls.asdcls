@EndUserText.label: 'Department Access Control (Ex. 17)'
@MappingRole: true
define role Z08_R_DEPARTMENT {
    grant 
        select
            on
                Z08_R_DEPARTMENT
                    where
                        (Id) = aspect pfcg_auth(Z08DPMENT, Z08DPMNT , ACTVT = '03');
                        
}